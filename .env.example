# Copy to .env and fill in values (do NOT commit .env)

# App Store Connect API Key (recommended for TestFlight uploads)
ASC_KEY_ID=
ASC_ISSUER_ID=
# Option A: store the key on disk
ASC_KEY_FILEPATH=
# Option B: store key content as base64 (avoid disk)
# ASC_KEY_BASE64=

# Optional overrides
# SCHEME=BetterLife
# XCODEPROJ=BetterLife.xcodeproj
# BUILD_NUMBER=123
